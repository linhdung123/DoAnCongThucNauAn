<% var hideSiteHeader = true; var bodyClass = 'page-tips'; %>
<%- include('../layout/header') %>

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700&family=Roboto:wght@400;500;700&display=swap" rel="stylesheet" />

<style>
  .tips-page {
    --tp-page: #fff3e0;
    --tp-nav-bg: #f0ebe1;
    --tp-dark: #262522;
    --tp-dark-08: rgba(38, 37, 34, 0.08);
    --tp-dark-24: rgba(38, 37, 34, 0.24);
    --tp-accent: #ff8d28;
    --tp-card-bg: #d9d9d9;
    --tp-card-shadow: 0 8px 24px rgba(0, 0, 0, 0.25);
    font-family: "Inter", "Segoe UI", system-ui, sans-serif;
    background: var(--tp-page);
    margin: 0;
    width: 100%;
    max-width: 100%;
    padding: 1.375rem 0 3.5rem;
    box-sizing: border-box;
  }

  .tips-page .cd-manage-nav-wrap {
    width: min(1312px, calc(100% - 2rem));
    margin: 0 auto 1.75rem;
  }

  .tips-page .cd-manage-nav {
    box-sizing: border-box;
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: 1rem 1.5rem;
    padding: 16px 24px;
    background: var(--tp-nav-bg);
    border: 1px solid var(--tp-dark-24);
    border-radius: 32px;
  }

  .tips-page .cd-nav-brand {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    color: var(--tp-dark);
    flex-shrink: 0;
  }

  .tips-page .cd-nav-logo {
    width: 40px;
    height: 35px;
    border-radius: 10px;
    border: 0.5px solid rgba(38, 38, 38, 0.5);
    background: linear-gradient(135deg, #ffd89b 0%, #ff9a56 100%);
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.35);
    flex-shrink: 0;
  }

  .tips-page .cd-nav-brand-text {
    font-family: "Roboto", sans-serif;
    font-weight: 700;
    font-size: 15px;
    line-height: 1.05;
    max-width: 7.5rem;
    letter-spacing: -0.02em;
  }

  .tips-page .cd-nav-links {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 24px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .tips-page .cd-nav-links a {
    font-family: "Roboto", sans-serif;
    font-weight: 500;
    font-size: 14px;
    line-height: 1;
    text-transform: uppercase;
    color: var(--tp-dark);
    text-decoration: none;
    white-space: nowrap;
  }

  .tips-page .cd-nav-links a.nav-tips {
    color: var(--tp-accent);
  }

  .tips-page .cd-nav-links a:not(.nav-tips):hover {
    opacity: 0.75;
  }

  .tips-page .cd-nav-actions {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 16px;
    flex-shrink: 0;
  }

  .tips-page .cd-nav-search-btn {
    display: inline-flex;
    justify-content: center;
    align-items: center;
    width: 37px;
    height: 37px;
    padding: 8px;
    background: var(--tp-dark-08);
    border-radius: 16px;
    color: var(--tp-dark);
    text-decoration: none;
    box-sizing: border-box;
  }

  .tips-page .cd-nav-search-btn:hover {
    background: rgba(38, 37, 34, 0.14);
  }

  .tips-page .cd-nav-search-btn svg {
    width: 21px;
    height: 21px;
  }

  .tips-page .cd-nav-login {
    display: inline-flex;
    justify-content: center;
    align-items: center;
    padding: 12px 24px;
    min-height: 38px;
    background: var(--tp-dark);
    border-radius: 24px;
    font-family: "Roboto", sans-serif;
    font-weight: 500;
    font-size: 14px;
    line-height: 1;
    text-transform: uppercase;
    color: var(--tp-nav-bg);
    text-decoration: none;
    box-sizing: border-box;
  }

  .tips-page .cd-nav-login:hover {
    filter: brightness(1.08);
  }

  .tips-page .tips-inner {
    width: min(1290px, calc(100% - 2rem));
    margin: 0 auto;
  }

  .tips-page .tips-hero {
    text-align: center;
    margin-bottom: 1.75rem;
  }

  .tips-page .tips-hero h1 {
    margin: 0 0 0.65rem;
    font-family: "Roboto", sans-serif;
    font-weight: 700;
    font-size: clamp(1.75rem, 5vw, 3.125rem);
    line-height: 1;
    text-transform: uppercase;
    color: #000;
  }

  .tips-page .tips-hero p {
    margin: 0 auto;
    max-width: 52rem;
    font-family: "Roboto", sans-serif;
    font-weight: 400;
    font-size: clamp(0.85rem, 2vw, 1.25rem);
    line-height: 1.35;
    text-transform: uppercase;
    color: #000;
  }

  .tips-page .tip-filters {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 0.75rem 1.5rem;
    margin-bottom: 2.25rem;
  }

  .tips-page .tip-filters a {
    display: inline-flex;
    justify-content: center;
    align-items: center;
    min-height: 34px;
    padding: 0.4rem 1.25rem;
    border-radius: 16px;
    background: var(--tp-accent);
    box-shadow: var(--tp-card-shadow);
    font-family: "Inter", sans-serif;
    font-size: 16px;
    line-height: 1.2;
    color: #000;
    text-decoration: none;
    font-weight: 400;
    border: none;
    box-sizing: border-box;
  }

  .tips-page .tip-filters a:hover {
    filter: brightness(1.06);
  }

  .tips-page .tip-filters a.is-active {
    font-weight: 700;
  }

  .tips-page .tip-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.5rem 2rem;
  }

  @media (max-width: 960px) {
    .tips-page .tip-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 560px) {
    .tips-page .tip-grid {
      grid-template-columns: 1fr;
    }
  }

  .tips-page .tip-card {
    background: var(--tp-card-bg);
    border-radius: 16px;
    box-shadow: var(--tp-card-shadow);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    width: 100%;
  }

  .tips-page .tip-card .tip-img {
    aspect-ratio: 269 / 158;
    margin: 0.65rem 0.75rem 0;
    border-radius: 16px;
    overflow: hidden;
    background: #c4c4c4;
    flex-shrink: 0;
  }

  .tips-page .tip-card .tip-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .tips-page .tip-card .tip-img .ph {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2.5rem;
    background: linear-gradient(145deg, #e8e4de, #d0ccc4);
  }

  .tips-page .tip-card .tip-body {
    padding: 0.85rem 0.85rem 1.1rem;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .tips-page .tip-card .tip-title {
    margin: 0;
    font-family: "Inter", sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 1.2;
    color: #000;
  }

  .tips-page .tip-card .tip-sum {
    margin: 0;
    font-family: "Inter", sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 1.2;
    color: #000;
  }

  .tips-page .tip-card .tip-meta {
    margin: 0;
    font-family: "Inter", sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 1.2;
    color: #000;
  }

  .tips-page .tip-card .tip-more {
    margin-top: 0.25rem;
    font-family: "Inter", sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 1.2;
    color: #000;
    text-decoration: underline;
    text-underline-offset: 2px;
    align-self: flex-start;
  }

  .tips-page .tip-card .tip-more:hover {
    opacity: 0.75;
  }

  .tips-page .tips-empty {
    text-align: center;
    font-family: "Roboto", sans-serif;
    font-weight: 500;
    color: #262522;
    padding: 2rem 1rem;
    background: var(--tp-nav-bg);
    border-radius: 16px;
    border: 1px solid var(--tp-dark-24);
    max-width: 28rem;
    margin: 0 auto;
  }
</style>

<section class="tips-page" aria-labelledby="tips-title">
  <div class="cd-manage-nav-wrap">
    <div class="cd-manage-nav">
      <a href="/" class="cd-nav-brand">
        <span class="cd-nav-logo" aria-hidden="true"></span>
        <span class="cd-nav-brand-text">Cooks Delight</span>
      </a>
      <ul class="cd-nav-links">
        <li><a href="/">Home</a></li>
        <li><a href="/list">Recipes</a></li>
        <li><a href="/tips" class="nav-tips">Tips</a></li>
        <li><a href="/list">Blog</a></li>
        <li><a href="/">About</a></li>
      </ul>
      <div class="cd-nav-actions">
        <a href="/search" class="cd-nav-search-btn" aria-label="Tìm kiếm">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <circle cx="11" cy="11" r="7" />
            <path d="M20 20l-4.3-4.3" stroke-linecap="round" />
          </svg>
        </a>
        <a href="/auth" class="cd-nav-login">Đăng nhập</a>
      </div>
    </div>
  </div>

  <div class="tips-inner">
    <header class="tips-hero">
      <h1 id="tips-title">Tips &amp; mẹo nấu ăn</h1>
      <p>Những bí quyết giúp bạn nấu ăn ngon – nhanh – chuẩn vị hơn mỗi ngày&nbsp;🍳</p>
    </header>

    <nav class="tip-filters" aria-label="Lọc theo chủ đề">
      <a class="<%= !activeCategory ? 'is-active' : '' %>" href="/tips">Tất cả</a>
      <% categories.forEach(function (cat) { %>
        <a
          class="<%= activeCategory === cat ? 'is-active' : '' %>"
          href="/tips?category=<%= encodeURIComponent(cat) %>"
        ><%= cat.replace(/-/g, '–') %></a>
      <% }); %>
    </nav>

    <% if (!tips || tips.length === 0) { %>
      <p class="tips-empty" role="status">Chưa có mẹo nào.</p>
    <% } else { %>
      <div class="tip-grid">
        <% tips.forEach(function (t) { %>
          <article class="tip-card">
            <div class="tip-img">
              <% if (t.image) { %>
                <img src="<%= t.image %>" alt="" loading="lazy" />
              <% } else { %>
                <div class="ph" aria-hidden="true">💡</div>
              <% } %>
            </div>
            <div class="tip-body">
              <h2 class="tip-title"><%= t.title %></h2>
              <p class="tip-sum"><%= t.summary %></p>
              <% if (t.timingNote) { %>
                <p class="tip-meta">⏱ <%= t.timingNote %></p>
              <% } %>
              <a class="tip-more" href="/tips/detail/<%= t._id %>">Xem chi tiết</a>
            </div>
          </article>
        <% }); %>
      </div>
    <% } %>
  </div>
</section>

<%- include('../layout/footer') %>
