<% var hideSiteHeader = true; var bodyClass = 'page-tips'; %>
<%- include('../layout/header') %>

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700&family=Roboto:wght@400;500;700&display=swap" rel="stylesheet" />

<style>
  .tip-detail-page {
    --tp-page: #fff3e0;
    --tp-nav-bg: #f0ebe1;
    --tp-dark: #262522;
    --tp-dark-08: rgba(38, 37, 34, 0.08);
    --tp-dark-24: rgba(38, 37, 34, 0.24);
    --tp-accent: #ff8d28;
    --tp-card-shadow: 0 8px 24px rgba(0, 0, 0, 0.25);
    font-family: "Inter", "Segoe UI", system-ui, sans-serif;
    background: var(--tp-page);
    margin: 0;
    width: 100%;
    max-width: 100%;
    padding: 1.375rem 0 3.5rem;
    box-sizing: border-box;
  }

  .tip-detail-page .cd-manage-nav-wrap {
    width: min(1312px, calc(100% - 2rem));
    margin: 0 auto 1.75rem;
  }

  .tip-detail-page .cd-manage-nav {
    box-sizing: border-box;
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: 1rem 1.5rem;
    padding: 16px 24px;
    background: var(--tp-nav-bg);
    border: 1px solid var(--tp-dark-24);
    border-radius: 32px;
  }

  .tip-detail-page .cd-nav-brand {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    color: var(--tp-dark);
    flex-shrink: 0;
  }

  .tip-detail-page .cd-nav-logo {
    width: 40px;
    height: 35px;
    border-radius: 10px;
    border: 0.5px solid rgba(38, 38, 38, 0.5);
    background: linear-gradient(135deg, #ffd89b 0%, #ff9a56 100%);
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.35);
    flex-shrink: 0;
  }

  .tip-detail-page .cd-nav-brand-text {
    font-family: "Roboto", sans-serif;
    font-weight: 700;
    font-size: 15px;
    line-height: 1.05;
    max-width: 7.5rem;
    letter-spacing: -0.02em;
  }

  .tip-detail-page .cd-nav-links {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 24px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .tip-detail-page .cd-nav-links a {
    font-family: "Roboto", sans-serif;
    font-weight: 500;
    font-size: 14px;
    line-height: 1;
    text-transform: uppercase;
    color: var(--tp-dark);
    text-decoration: none;
    white-space: nowrap;
  }

  .tip-detail-page .cd-nav-links a.nav-tips {
    color: var(--tp-accent);
  }

  .tip-detail-page .cd-nav-links a:not(.nav-tips):hover {
    opacity: 0.75;
  }

  .tip-detail-page .cd-nav-actions {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 16px;
    flex-shrink: 0;
  }

  .tip-detail-page .cd-nav-search-btn {
    display: inline-flex;
    justify-content: center;
    align-items: center;
    width: 37px;
    height: 37px;
    padding: 8px;
    background: var(--tp-dark-08);
    border-radius: 16px;
    color: var(--tp-dark);
    text-decoration: none;
    box-sizing: border-box;
  }

  .tip-detail-page .cd-nav-search-btn:hover {
    background: rgba(38, 37, 34, 0.14);
  }

  .tip-detail-page .cd-nav-search-btn svg {
    width: 21px;
    height: 21px;
  }

  .tip-detail-page .cd-nav-login {
    display: inline-flex;
    justify-content: center;
    align-items: center;
    padding: 12px 24px;
    min-height: 38px;
    background: var(--tp-dark);
    border-radius: 24px;
    font-family: "Roboto", sans-serif;
    font-weight: 500;
    font-size: 14px;
    line-height: 1;
    text-transform: uppercase;
    color: var(--tp-nav-bg);
    text-decoration: none;
    box-sizing: border-box;
  }

  .tip-detail-page .cd-nav-login:hover {
    filter: brightness(1.08);
  }

  .tip-detail-page .inner {
    width: min(720px, calc(100% - 2rem));
    margin: 0 auto;
    background: #fff;
    border-radius: 16px;
    box-shadow: var(--tp-card-shadow);
    padding: 1.5rem 1.35rem 2rem;
    box-sizing: border-box;
  }

  .tip-detail-page .back {
    display: inline-block;
    margin-bottom: 1rem;
    font-family: "Roboto", sans-serif;
    font-weight: 500;
    font-size: 14px;
    color: var(--tp-accent);
    text-decoration: none;
    text-transform: uppercase;
  }

  .tip-detail-page .back:hover {
    text-decoration: underline;
  }

  .tip-detail-page .badge {
    display: inline-block;
    font-family: "Inter", sans-serif;
    font-size: 14px;
    font-weight: 700;
    background: var(--tp-accent);
    color: #000;
    padding: 0.35rem 0.9rem;
    border-radius: 16px;
    box-shadow: var(--tp-card-shadow);
    margin-bottom: 0.75rem;
  }

  .tip-detail-page h1 {
    margin: 0 0 0.5rem;
    font-family: "Roboto", sans-serif;
    font-weight: 700;
    font-size: clamp(1.35rem, 3vw, 1.85rem);
    line-height: 1.2;
    text-transform: uppercase;
    color: #000;
  }

  .tip-detail-page .meta {
    font-family: "Inter", sans-serif;
    font-size: 16px;
    color: #000;
    margin: 0 0 1.25rem;
  }

  .tip-detail-page .img-box {
    border-radius: 16px;
    overflow: hidden;
    margin-bottom: 1.25rem;
    aspect-ratio: 269 / 158;
    max-height: 320px;
    background: #d9d9d9;
  }

  .tip-detail-page .img-box img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .tip-detail-page .img-box .ph {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 3rem;
    background: linear-gradient(145deg, #e8e4de, #d0ccc4);
  }

  .tip-detail-page .body {
    font-family: "Inter", sans-serif;
    font-size: 16px;
    line-height: 1.55;
    color: #000;
    white-space: pre-wrap;
    margin: 0;
  }
</style>

<section class="tip-detail-page">
  <div class="cd-manage-nav-wrap">
    <div class="cd-manage-nav">
      <a href="/" class="cd-nav-brand">
        <span class="cd-nav-logo" aria-hidden="true"></span>
        <span class="cd-nav-brand-text">Cooks Delight</span>
      </a>
      <ul class="cd-nav-links">
        <li><a href="/">Home</a></li>
        <li><a href="/list">Recipes</a></li>
        <li><a href="/tips" class="nav-tips">Tips</a></li>
        <li><a href="/list">Blog</a></li>
        <li><a href="/">About</a></li>
      </ul>
      <div class="cd-nav-actions">
        <a href="/search" class="cd-nav-search-btn" aria-label="Tìm kiếm">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <circle cx="11" cy="11" r="7" />
            <path d="M20 20l-4.3-4.3" stroke-linecap="round" />
          </svg>
        </a>
        <a href="/auth" class="cd-nav-login">Đăng nhập</a>
      </div>
    </div>
  </div>

  <div class="inner">
    <a class="back" href="/tips">← Quay lại Tips</a>
    <span class="badge"><%= tip.category.replace(/-/g, '–') %></span>
    <h1><%= tip.title %></h1>
    <% if (tip.timingNote) { %>
      <p class="meta">⏱ <%= tip.timingNote %></p>
    <% } %>
    <div class="img-box">
      <% if (tip.image) { %>
        <img src="<%= tip.image %>" alt="" />
      <% } else { %>
        <div class="ph" aria-hidden="true">💡</div>
      <% } %>
    </div>
    <p class="body"><%= tip.content || tip.summary || '' %></p>
  </div>
</section>

<%- include('../layout/footer') %>
