<%- include('../layout/header') %>

<style>
  .edit-wrap { max-width: 640px; margin: 0 auto; padding: 2rem 0 3rem; }
  .edit-eyebrow { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.12em; color: #b91c1c; font-weight: 700; margin: 0 0 0.35rem; }
  .edit-title { margin: 0 0 0.35rem; font-size: clamp(1.35rem, 3vw, 1.75rem); }
  .edit-sub { margin: 0 0 1.5rem; color: var(--color-muted); }
  .edit-card {
    background: var(--color-surface); border-radius: var(--radius); box-shadow: var(--shadow);
    padding: 1.5rem; border: 1px solid var(--color-border); margin-bottom: 1.25rem;
  }
  .edit-card h2 { margin: 0 0 1rem; font-size: 1.05rem; }
  .form-row { margin-bottom: 1rem; }
  .form-row label { display: block; font-weight: 600; font-size: 0.9rem; margin-bottom: 0.35rem; }
  .form-row input[type="text"],
  .form-row input[type="password"],
  .form-row textarea {
    width: 100%; padding: 0.65rem 0.75rem; border: 1px solid var(--color-border); border-radius: var(--radius); font: inherit;
  }
  .form-row textarea { min-height: 100px; resize: vertical; }
  .form-hint { font-size: 0.8rem; color: var(--color-muted); margin: 0.35rem 0 0; }
  .avatar-edit { display: flex; align-items: center; gap: 1.25rem; flex-wrap: wrap; }
  .avatar-edit-preview { position: relative; width: 96px; height: 96px; flex-shrink: 0; }
  .avatar-edit-preview img, .avatar-edit-ph {
    width: 96px; height: 96px; border-radius: 50%; object-fit: cover; background: #e8e4de;
  }
  .avatar-edit-ph { display: flex; align-items: center; justify-content: center; font-size: 1.75rem; font-weight: 700; color: var(--color-muted); }
  .avatar-upload-btn {
    display: inline-block; padding: 0.45rem 0.9rem; background: #7c3aed; color: #fff; border-radius: 999px; font-size: 0.85rem; font-weight: 600; cursor: pointer;
  }
  .avatar-upload-btn:hover { filter: brightness(1.08); }
  .avatar-upload-btn input { display: none; }
  .form-actions { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 1.25rem; }
  .btn-save {
    padding: 0.65rem 1.35rem; border-radius: var(--radius); font-weight: 600; border: none; cursor: pointer; font: inherit;
    background: #b91c1c; color: #fff;
  }
  .btn-save:hover { filter: brightness(1.05); }
  .btn-cancel {
    padding: 0.65rem 1.35rem; border-radius: var(--radius); font-weight: 600; text-decoration: none; color: var(--color-muted);
    border: 1px solid var(--color-border); background: var(--color-surface); display: inline-block; font: inherit;
  }
  .btn-cancel:hover { border-color: var(--color-muted); color: var(--color-text); }
  .form-error { background: #fef2f2; border: 1px solid #fecaca; color: #991b1b; padding: 0.75rem 1rem; border-radius: var(--radius); margin-bottom: 1rem; font-size: 0.9rem; }
</style>

<div class="container edit-wrap">
  <p class="edit-eyebrow">Cài đặt tài khoản</p>
  <h1 class="edit-title">Chỉnh sửa hồ sơ</h1>
  <p class="edit-sub">Cập nhật tên hiển thị, giới thiệu, ảnh đại diện và mật khẩu.</p>

  <% if (typeof error !== 'undefined' && error) { %>
    <p class="form-error" role="alert"><%= error %></p>
  <% } %>

  <form action="/profile/edit" method="post" enctype="multipart/form-data">
    <div class="edit-card">
      <h2>Ảnh đại diện</h2>
      <div class="avatar-edit">
        <div class="avatar-edit-preview">
          <% if (user.avatar) { %>
            <img src="<%= user.avatar %>" alt="" width="96" height="96" />
          <% } else { %>
            <div class="avatar-edit-ph" aria-hidden="true"><%= (user.username || '?').charAt(0).toUpperCase() %></div>
          <% } %>
        </div>
        <div>
          <label class="avatar-upload-btn">
            Chọn ảnh mới
            <input type="file" name="avatar" accept="image/jpeg,image/png,image/gif,image/webp" />
          </label>
          <p class="form-hint">JPEG, PNG, GIF hoặc WebP — tối đa 2MB. Để trống nếu giữ ảnh hiện tại.</p>
        </div>
      </div>
    </div>

    <div class="edit-card">
      <h2>Thông tin công khai</h2>
      <div class="form-row">
        <label for="username">Tên hiển thị</label>
        <input type="text" id="username" name="username" value="<%= user.username %>" required maxlength="80" />
      </div>
      <div class="form-row">
        <label for="bio">Giới thiệu ngắn (bio)</label>
        <textarea id="bio" name="bio" maxlength="2000" placeholder="Chia sẻ vài dòng về bạn…"><%= user.bio || '' %></textarea>
      </div>
    </div>

    <div class="edit-card">
      <h2>Đổi mật khẩu</h2>
      <p class="form-hint" style="margin:0 0 1rem">Để trống cả ba ô nếu bạn không muốn đổi mật khẩu.</p>
      <div class="form-row">
        <label for="oldPassword">Mật khẩu hiện tại</label>
        <input type="password" id="oldPassword" name="oldPassword" autocomplete="current-password" />
      </div>
      <div class="form-row">
        <label for="newPassword">Mật khẩu mới</label>
        <input type="password" id="newPassword" name="newPassword" autocomplete="new-password" />
      </div>
      <div class="form-row">
        <label for="confirmPassword">Xác nhận mật khẩu mới</label>
        <input type="password" id="confirmPassword" name="confirmPassword" autocomplete="new-password" />
      </div>
    </div>

    <div class="form-actions">
      <button type="submit" class="btn-save">Lưu thay đổi</button>
      <a class="btn-cancel" href="/profile">Hủy</a>
    </div>
  </form>
</div>

<%- include('../layout/footer') %>