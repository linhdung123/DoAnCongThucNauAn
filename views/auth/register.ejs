<%- include('../layout/auth-head', { title: typeof title !== 'undefined' ? title : 'Đăng ký' }) %>
<header class="auth-topbar" role="banner">
  <div class="auth-topbar-inner">
    <img class="auth-mascot" src="/images/chef-mascot.png" alt="" width="103" height="103" onerror="this.style.display='none'; this.nextElementSibling.style.display='block';" />
    <span class="auth-mascot auth-mascot--fallback" style="display:none" aria-hidden="true">🧑‍🍳</span>
  </div>
</header>

<main class="auth-main">
  <div class="auth-panel">
    <div class="auth-title-row">
      <h1 class="auth-welcome">Welcome to Cooks Delight</h1>
    </div>
    <p class="auth-heading">Sign Up</p>

    <% if (typeof error !== 'undefined' && error) { %>
      <p class="auth-alert" role="alert"><%= error %></p>
    <% } %>

    <form class="auth-form" method="post" action="/auth/register" novalidate>
      <div class="auth-field">
        <label class="auth-label visually-hidden" for="fullName">Họ tên</label>
        <div class="auth-input-wrap">
          <span class="auth-input-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          </span>
          <input class="auth-input" type="text" id="fullName" name="fullName" autocomplete="name" required placeholder="Username" value="<%= typeof fullName !== 'undefined' ? fullName : '' %>" />
        </div>
      </div>

      <div class="auth-field">
        <label class="auth-label visually-hidden" for="email">Email</label>
        <div class="auth-input-wrap">
          <span class="auth-input-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </span>
          <input class="auth-input" type="email" id="email" name="email" autocomplete="email" required placeholder="Email" value="<%= typeof email !== 'undefined' ? email : '' %>" />
        </div>
      </div>

      <div class="auth-field">
        <label class="auth-label visually-hidden" for="reg-password">Password</label>
        <div class="auth-input-wrap">
          <span class="auth-input-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          </span>
          <input class="auth-input" type="password" id="reg-password" name="password" autocomplete="new-password" required placeholder="Password" />
          <button type="button" class="auth-toggle-vis" data-password-toggle aria-controls="reg-password" aria-label="Hiện mật khẩu" aria-pressed="false">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
          </button>
        </div>
      </div>

      <div class="auth-field">
        <label class="auth-label visually-hidden" for="password2">Xác nhận mật khẩu</label>
        <div class="auth-input-wrap">
          <span class="auth-input-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          </span>
          <input class="auth-input" type="password" id="password2" name="password2" autocomplete="new-password" required placeholder="Confirm password" />
          <button type="button" class="auth-toggle-vis" data-password-toggle aria-controls="password2" aria-label="Hiện mật khẩu" aria-pressed="false">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
          </button>
        </div>
      </div>

      <div class="auth-actions">
        <button type="submit" class="auth-btn">SIGN UP</button>
      </div>
    </form>

    <p class="auth-footnote">Already have an account? <a href="/auth/login">Sign In</a></p>
  </div>
</main>
<%- include('../layout/auth-foot') %>
