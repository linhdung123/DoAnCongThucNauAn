<%- include('../layout/auth-shell') %>

<div class="auth-panel">
  <div class="auth-panel-inner">
    <p class="auth-subtitle">Forgot Password</p>
    <p class="auth-hint-block">Enter your email to reset your password</p>
    <p id="auth-msg" class="auth-message auth-message--ok" role="status"></p>

    <form id="form-forgot" class="auth-form" novalidate>
      <div class="auth-field">
        <label class="auth-field-label" for="fp-email">Email</label>
        <div class="auth-input-wrap">
          <span class="auth-input-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </span>
          <input id="fp-email" name="email" type="email" autocomplete="email" placeholder="Email" required />
        </div>
      </div>

      <div class="auth-actions">
        <button type="submit" class="auth-btn">SEND CODE</button>
      </div>

      <p class="auth-footer-note">Remembered? <a href="/auth/login">Sign In</a></p>
    </form>
  </div>
</div>

<script>
(function () {
  var form = document.getElementById('form-forgot');
  var msg = document.getElementById('auth-msg');
  function showMsg(text, ok) {
    msg.textContent = text || '';
    msg.classList.toggle('is-visible', !!text);
    msg.classList.toggle('auth-message--error', !ok);
    msg.classList.toggle('auth-message--ok', !!ok);
  }
  form.addEventListener('submit', function (e) {
    e.preventDefault();
    var email = (document.getElementById('fp-email').value || '').trim();
    if (!email) {
      showMsg('Vui lòng nhập email.', false);
      return;
    }
    fetch('/auth/forgot', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      credentials: 'same-origin',
      body: JSON.stringify({ email: email })
    })
      .then(function (r) { return r.json().then(function (j) { return { ok: r.ok, j: j }; }); })
      .then(function (x) {
        if (!x.ok) throw new Error(x.j.message || 'Không gửi được');
        showMsg(x.j.message || 'Đã xử lý.', true);
      })
      .catch(function (err) { showMsg(err.message || 'Lỗi', false); });
  });
})();
</script>

<%- include('../layout/auth-end') %>
