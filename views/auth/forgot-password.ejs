<%- include('../layout/auth-head', { title: typeof title !== 'undefined' ? title : 'Quên mật khẩu' }) %>
<header class="auth-topbar" role="banner">
  <div class="auth-topbar-inner">
    <img class="auth-mascot" src="/images/chef-mascot.png" alt="" width="103" height="103" onerror="this.style.display='none'; this.nextElementSibling.style.display='block';" />
    <span class="auth-mascot auth-mascot--fallback" style="display:none" aria-hidden="true">🧑‍🍳</span>
  </div>
</header>

<main class="auth-main">
  <div class="auth-panel">
    <div class="auth-title-row">
      <h1 class="auth-welcome">Welcome to Cooks Delight</h1>
    </div>
    <p class="auth-heading">Forgot Password</p>

    <p class="auth-hint">Enter your email to reset your password</p>

    <% if (typeof error !== 'undefined' && error) { %>
      <p class="auth-alert" role="alert"><%= error %></p>
    <% } %>
    <% if (typeof info !== 'undefined' && info) { %>
      <p class="auth-alert" role="status"><%= info %></p>
    <% } %>

    <form class="auth-form" method="post" action="/auth/forgot-password" novalidate>
      <div class="auth-field">
        <label class="auth-label visually-hidden" for="reset-email">Email</label>
        <div class="auth-input-wrap">
          <span class="auth-input-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </span>
          <input class="auth-input" type="email" id="reset-email" name="email" autocomplete="email" required placeholder="Email" value="<%= typeof email !== 'undefined' ? email : '' %>" />
        </div>
      </div>

      <div class="auth-actions">
        <button type="submit" class="auth-btn auth-btn--inter">SEND CODE</button>
      </div>
    </form>

    <p class="auth-footnote">Remembered? <a href="/auth/login">Sign In</a></p>
  </div>
</main>
<%- include('../layout/auth-foot') %>
