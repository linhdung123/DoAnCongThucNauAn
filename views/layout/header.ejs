<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof title !== 'undefined' ? title : 'Cooks Delight' %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <header class="site-header">
    <div class="container header-shell">
      <div class="header-bar">
        <a href="/" class="brand" aria-label="Cooks Delight — Trang chủ">
          <span class="brand-mark" aria-hidden="true">
            <svg width="36" height="36" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect width="40" height="40" rx="10" fill="#F0EBE1"/>
              <path d="M12 26V14h3v12h-3zm5-8c0-2.2 1.8-4 4-4s4 1.8 4 4v8h-3v-8c0-.6-.4-1-1-1s-1 .4-1 1v8h-3v-8z" fill="#262522"/>
              <path d="M10 12l10-4 10 4v2H10v-2z" fill="#FF8D28"/>
            </svg>
          </span>
          <span class="brand-text">Cooks Delight</span>
        </a>

        <nav class="main-nav" aria-label="Chính">
          <a href="/" class="nav-link <%= typeof navActive !== 'undefined' && navActive === 'home' ? 'is-active' : '' %>">Trang chủ</a>
          <a href="/list" class="nav-link <%= typeof navActive !== 'undefined' && navActive === 'cam-nang' ? 'is-active' : '' %>">Cẩm nang</a>
          <a href="/favorites" class="nav-link <%= typeof navActive !== 'undefined' && navActive === 'favorites' ? 'is-active' : '' %>">Món yêu thích</a>
          <a href="/search" class="nav-link <%= typeof navActive !== 'undefined' && navActive === 'tips' ? 'is-active' : '' %>">Tips</a>
          <a href="#gioi-thieu" class="nav-link <%= typeof navActive !== 'undefined' && navActive === 'about' ? 'is-active' : '' %>">Giới thiệu</a>
        </nav>

        <div class="header-actions">
          <a href="/search" class="search-icon-btn" aria-label="Tìm kiếm">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
              <circle cx="11" cy="11" r="7" />
              <path d="M20 20l-4.3-4.3" />
            </svg>
          </a>
          <a href="/profile" class="btn-profile">Cá nhân</a>
        </div>
      </div>
    </div>
  </header>
  <main class="site-main">
